---
import { Icon } from 'astro-icon/components';
import Link from '../components/Link.astro';
---

<footer
  id='contact'
  class='w-full p-4 bg-gray-50 dark:bg-lighter-dark-bg'
  role='contentinfo'
>
  <div class='max-w-3xl mx-auto'>
    <p
      class='flex justify-center items-center text-gray-600 dark:text-gray-400'
    >
      <Link url='/privacy-policy' self={true}>Privacy Policy</Link>
      <Icon name='lucide:dot' class='w-6 h-6' aria-hidden='true' />
      <Link url='/copyright' self={true}>Copyright</Link>
    </p>
  </div>
</footer>

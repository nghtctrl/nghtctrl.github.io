---
import { Icon } from 'astro-icon/components';

interface Props {
  href: string;
  isExternal?: boolean;
  hideIcon?: boolean;
}

const { href, isExternal = false, hideIcon = false } = Astro.props;
---

<a
  href={href}
  target={isExternal ? '_blank' : '_self'}
  rel={isExternal ? 'noopener noreferrer' : undefined}
  class='not-prose inline-flex items-center gap-1 font-normal text-blue-800 hover:text-blue-700 dark:text-blue-300 dark:hover:text-blue-200'
>
  <slot />
  {isExternal && !hideIcon && <Icon name='lucide:external-link' aria-hidden='true' class='size-[1em] shrink-0' />}
  {isExternal && <span class='sr-only'>Opens in a new tab</span>}
</a>

---
import Layout from '../layouts/Layout.astro';
import Link from '../components/Link.astro';

const metadata = {
  title: 'Page Not Found',
  useTitleTemplate: true,
  index: false,
};
---

<Layout metadata={metadata}>
  <h1>Page Not Found</h1>
  <p>
    This page may have been moved, renamed, removed, or may not exist. If an AI
    chatbot or search engine summary brought you here, it may have <Link
      url='https://en.wikipedia.org/wiki/Hallucination_(artificial_intelligence)'
      >hallucinated a nonexistent page</Link
    >.
  </p>
  <p>Here's what you can do:</p>
  <ul>
    <li>Check the URL for typos.</li>
    <li>Go back to the previous page.</li>
    <li>Browse the menu to find what you're looking for.</li>
  </ul>
</Layout>

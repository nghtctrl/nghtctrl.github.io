---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import PaperCard from '../components/PaperCard.astro';
import SocialMediaButton from '../components/SocialMediaButton.astro';
import Link from '../components/Link.astro';
import profilePicture from '../assets/profile-picture.webp';
import kim2025Cupid from '../assets/paper_thumbnails/kim-2025-cupid.webp';
---

<Layout>
  <div class='flex flex-col-reverse md:flex-row'>
    <div class='text-center md:text-left mr-4'>
      <div class='not-prose hidden md:block'>
        <h1
          class='text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100'
        >
          Jiho Kim
        </h1>
        <p>he/him</p>
      </div>
      <p>
        Hey there! I am currently working as a Software Developer at <Link
          href='https://software.sil.org/'
          isExternal>SIL Language Technology</Link
        >.
      </p>
      <p>
        I recently completed a B.C.S in Computer Science from Calvin University,
        where I was fortunate to be advised by <Link
          href='https://kenarnold.org/'
          isExternal>Ken Arnold</Link
        >.
      </p>
      <p>
        My research interest is in human-AI interaction. I am interested in
        studying how AI impacts the way we reflect, express ourselves,
        communicate with others, and learn.
      </p>
      <p>
        You can reach me at <span class='italic'>myfirstname</span>@jihokim.com
      </p>
    </div>
    <div>
      <Image
        src={profilePicture}
        alt='Jiho Kim'
        class='mx-auto max-w-60 rounded-lg object-cover'
      />
      <div
        class='flex flex-col gap-4 md:mx-auto mt-6 md:mt-4 mb-4 md:mb-0 md:flex-row md:gap-0 md:justify-between'
      >
        <SocialMediaButton
          href='/jiho-kim-cv.pdf'
          label='Curriculum Vitae'
          icon='academicons:cv'
        />
        <SocialMediaButton
          href='https://github.com/nghtctrl'
          label='GitHub'
          icon='fa7-brands:github'
          hoverColor='#101411'
        />
        <SocialMediaButton
          href='https://www.linkedin.com/in/jiho-kim-128aa0199'
          label='LinkedIn'
          icon='fa7-brands:linkedin'
          hoverColor='#0077B5'
        />
        <SocialMediaButton
          href='https://scholar.google.com/citations?hl=en&user=aWisTO4AAAAJ&view_op=list_works&sortby=pubdate'
          label='Google Scholar'
          icon='academicons:google-scholar'
          hoverColor='#4285F4'
        />
        <SocialMediaButton
          href='https://www.semanticscholar.org/author/Jiho-Kim/2289885996?sort=pub-date'
          label='Semantic Scholar'
          icon='academicons:semantic-scholar'
          hoverColor='#11223C'
        />
      </div>
    </div>
  </div>

  <div>
    <h2>What's New?</h2>
    <ul>
      <li>
        <strong>July 29, 2025:</strong> I started working as a Software Developer
        at SIL Language Technology.
      </li>
      <li>
        <strong>May 4, 2025:</strong> I presented the posters of my two workshop papers
        at the In2Writing workshop at NAACL '25 in Albuquerque, NM.
      </li>
      <li>
        <strong>November 2, 2024:</strong> I was invited to give a talk about my undergraduate
        research at WMRUGS '24 in Grand Rapids, MI.
      </li>
    </ul>

    <h2>Publications</h2>
    <h3>Conference Papers</h3>
    <div class='mt-4 flex flex-col gap-8'>
      <PaperCard
        title='CUPID: Evaluating Personalized and Contextualized Alignment of LLMs from Interactions'
        authors='Tae Soo Kim, Yoonjoo Lee, Yoonah Park, Jiho Kim, Young-Ho Kim, and Juho Kim'
        venue='Second Conference on Language Modeling (COLM 2025)'
        imageSrc={kim2025Cupid}
        pdfUrl='/papers/kim-2025-cupid.pdf'
        websiteUrl='https://cupid.kixlab.org'
        datasetUrl='https://huggingface.co/datasets/kixlab/CUPID'
        bibtexUrl='/paper_bibtex/kim-2025-cupid.txt'
      />
    </div>

    <h3>Workshop Papers, Posters, and Technical Reports</h3>
    <div class='flex flex-col gap-4 mt-4'>
      <PaperCard
        title='Voice Interaction With Conversational AI Could Facilitate Thoughtful Reflection and Substantive Revision in Writing'
        authors="Jiho Kim, Philippe Laban, Xiang 'Anthony' Chen, and Kenneth C. Arnold"
        venue='Fourth Workshop on Intelligent and Interactive Writing Assistants (In2Writing 2025) at NAACL 2025'
        pdfUrl='/papers/kim-2025-voice-interaction.pdf'
        posterUrl='/posters/kim-2025-voice-interaction.pdf'
        bibtexUrl='/paper_bibtex/kim-2025-voice-interaction.txt'
      />
      <PaperCard
        title='Interaction-Required Suggestions for Control, Ownership, and Awareness in Human-AI Co-Writing'
        authors='Kenneth C. Arnold and Jiho Kim'
        venue='Fourth Workshop on Intelligent and Interactive Writing Assistants (In2Writing 2025) at NAACL 2025'
        pdfUrl='/papers/arnold-2025-interaction-required-suggestions.pdf'
        demoUrl='https://huggingface.co/spaces/CalvinU/writing-prototypes'
        posterUrl='/posters/arnold-2025-interaction-required-suggestions.pdf'
        bibtexUrl='/paper_bibtex/arnold-2025-interaction-required-suggestions.txt'
      />
      <PaperCard
        title='Towards Full Authorship with AI: Supporting Revision with AI-Generated Views'
        authors='Jiho Kim, Ray C. Flanagan, Noelle E. Haviland, ZeAi Sun, Souad N. Yakubu, Edom A. Maru, and Kenneth C. Arnold'
        venue='Fifth Workshop on Human-AI Co-Creation with Generative Models (HAI-GEN 2024) at IUI 2024'
        pdfUrl='/papers/kim-2024-towards-full-authorship-with-ai.pdf'
        demoUrl='https://app.thoughtful-ai.com/'
        posterUrl='/posters/kim-2024-towards-full-authorship-with-ai.pdf'
        videoUrl='https://www.youtube.com/watch?v=-s6IvkGqj2Q'
        bibtexUrl='/paper_bibtex/kim-2024-towards-full-authorship-with-ai.txt'
      />
    </div>
  </div>
</Layout>
